# Full SVMC build for R package.
# Build order respects Fortran module dependencies.
#
# The model .f90 files use `real` which must be promoted to 8-byte
# to match the vendor build.  -fdefault-real-8 promotes default REAL
# to REAL(8); pair with -fdefault-double-8 so DOUBLE PRECISION stays
# at REAL(8) (without it, gfortran/flang would promote DP to REAL(16)).
# Works for both gfortran (native) and flang (WebR/WASM).

PKG_FFLAGS  = -fdefault-real-8 -fdefault-double-8
PKG_FCFLAGS = -fdefault-real-8 -fdefault-double-8

OBJECTS = readctrl_stub.o readvegpara_stub.o readsoilpara_stub.o \
          blas.o linpack.o lbfgsb.o timer.o \
          juldate.o \
          yassofortran20.o yasso.o wrapper_yasso.o \
          phydro_mod.o water_mod.o \
          allocation.o allocation_wrappers.o \
          svmc_wrapper.o init.o
